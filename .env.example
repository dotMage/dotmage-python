# Copy to .env and fill in. Read by the SDK via pydantic-settings (prefix DOTMAGE_).

# Base URL of your dotMage server.
DOTMAGE_SERVER_URL=https://secrets.example.com

# Device token (dmage_dtok_...) and its refresh token (dmage_rtok_...).
# For CI, this is typically a scoped token created with gen_ci_token().
DOTMAGE_DEVICE_TOKEN=
DOTMAGE_REFRESH_TOKEN=

# Master password used to unlock (decrypt the account key). Keep it in a secret store.
DOTMAGE_MASTER_PASSWORD=

# Optional HTTP tuning.
# DOTMAGE_TIMEOUT=10.0
# DOTMAGE_MAX_RETRIES=5
# DOTMAGE_LOG_LEVEL=INFO
